@inherits LayoutComponentBase

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="alert alert-warning text-center mb-0" role="alert" style="border-radius: 0; border-left: 0; border-right: 0;">
            <strong>Development Environment:</strong> This environment represents a working proof of concept for exploration and learning.
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
