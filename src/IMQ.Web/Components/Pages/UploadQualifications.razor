@page "/upload-qualifications"
@using IMQ.Core.Interfaces
@using Microsoft.JSInterop
@inject IDocumentParsingService DocumentParsingService
@inject NavigationManager Navigation
@inject IConfiguration Configuration
@inject IJSRuntime JSRuntime
@rendermode InteractiveServer

<PageTitle>Upload Qualifications - IMQ</PageTitle>

<h1>
    <i class="bi bi-cloud-upload"></i> Upload Qualifications
</h1>
<p class="lead">Upload your CV or training certificates to automatically extract qualifications</p>
<p class="text-muted mb-4">Save time, reduce manual entry, and keep your qualifications profile audit-ready.</p>

<!-- How It Works Section - Moved to top for better hierarchy -->
<div class="row mb-4">
    <div class="col-12">
        <div class="card how-it-works-card border-primary shadow-sm">
            <div class="card-header bg-primary text-white">
                <h4 class="mb-0 fw-bold">
                    <i class="bi bi-info-circle-fill"></i> How It Works
                </h4>
                <p class="mb-0 mt-2" style="font-size: 0.95rem; opacity: 0.9;">
                    Here's how your document is securely processed and parsed using AI.
                </p>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-3 col-sm-6 mb-3 text-center step-animate" style="animation-delay: 0s;">
                        <div class="step-icon mb-2">
                            <i class="bi bi-file-earmark-arrow-up display-4 text-primary"></i>
                        </div>
                        <h6 class="fw-bold">1. Upload</h6>
                        <small class="text-muted">Upload your CV or certificate</small>
                    </div>
                    <div class="col-md-3 col-sm-6 mb-3 text-center step-animate" style="animation-delay: 0.15s;">
                        <div class="step-icon mb-2">
                            <i class="bi bi-robot display-4 text-primary"></i>
                        </div>
                        <h6 class="fw-bold">2. AI Parse</h6>
                        <small class="text-muted">AI extracts qualifications automatically</small>
                    </div>
                    <div class="col-md-3 col-sm-6 mb-3 text-center step-animate" style="animation-delay: 0.3s;">
                        <div class="step-icon mb-2">
                            <i class="bi bi-pencil-square display-4 text-primary"></i>
                        </div>
                        <h6 class="fw-bold">3. Review</h6>
                        <small class="text-muted">Review and edit extracted data</small>
                    </div>
                    <div class="col-md-3 col-sm-6 mb-3 text-center step-animate" style="animation-delay: 0.45s;">
                        <div class="step-icon mb-2">
                            <i class="bi bi-check-circle-fill display-4 text-success"></i>
                        </div>
                        <h6 class="fw-bold">4. Save</h6>
                        <small class="text-muted">Save to your profile</small>
                    </div>
                </div>
                <div class="alert alert-info mb-0 mt-3">
                    <small>
                        <i class="bi bi-shield-lock-fill"></i> <strong>Privacy:</strong> Documents are processed in real-time and not permanently stored. 
                        Only the extracted qualification data is saved to your profile.
                    </small>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row mt-4">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">
                    <i class="bi bi-file-earmark-pdf"></i> Document Upload
                </h5>
            </div>
            <div class="card-body">
                @if (isProcessing)
                {
                    <div class="text-center py-5">
                        <div class="spinner-border text-primary mb-3" role="status" style="width: 3rem; height: 3rem;">
                            <span class="visually-hidden">Processing...</span>
                        </div>
                        <h5 class="mb-2">@processingMessage</h5>
                        <div class="progress mx-auto mb-3" style="width: 60%; height: 8px;">
                            <div class="progress-bar progress-bar-striped progress-bar-animated bg-primary" 
                                 role="progressbar" 
                                 style="width: @(processingProgress)%">
                            </div>
                        </div>
                        <p class="text-muted small">@processingSubMessage</p>
                    </div>
                }
                else if (allQualifications.Any())
                {
                    <!-- AI Summary Panel -->
                    <div class="alert alert-primary mb-4">
                        <h6 class="alert-heading"><i class="bi bi-robot"></i> AI Extraction Summary</h6>
                        <p class="mb-0">
                            <strong>@allQualifications.Count</strong> qualification(s) extracted from <strong>@processedFiles.Count</strong> document(s).
                            @if (GetFlaggedCount() > 0)
                            {
                                <span class="text-warning"><i class="bi bi-exclamation-triangle-fill"></i> @GetFlaggedCount() flagged for review.</span>
                            }
                            @if (GetIncompleteCount() > 0)
                            {
                                <span class="text-muted"><i class="bi bi-info-circle-fill"></i> @GetIncompleteCount() incomplete entry(ies).</span>
                            }
                        </p>
                    </div>

                    <!-- Processed Files List -->
                    @if (processedFiles.Any())
                    {
                        <div class="card mb-4 border-info">
                            <div class="card-header bg-light">
                                <h6 class="mb-0"><i class="bi bi-files"></i> Processed Documents</h6>
                            </div>
                            <div class="card-body">
                                <div class="d-flex flex-wrap gap-2">
                                    @foreach (var file in processedFiles)
                                    {
                                        <span class="badge bg-info text-dark fs-6 p-2">
                                            <i class="bi bi-file-earmark-check"></i> @file
                                        </span>
                                    }
                                </div>
                            </div>
                        </div>
                    }

                    @if (!string.IsNullOrWhiteSpace(parseResult?.RoleSummary))
                    {
                        <div class="card mb-4 border-primary">
                            <div class="card-header bg-primary text-white">
                                <h6 class="mb-0">
                                    <i class="bi bi-person-badge"></i> Recommended Roles in Health Sciences Studies
                                </h6>
                            </div>
                            <div class="card-body">
                                <p class="mb-0">@parseResult.RoleSummary</p>
                            </div>
                        </div>
                    }

                    <h5 class="mt-4 mb-3">Extracted Qualifications <span class="badge bg-secondary">@allQualifications.Count</span></h5>
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Skill/Certification</th>
                                    <th>Date Acquired</th>
                                    <th>Expiration</th>
                                    <th>Issuing Authority</th>
                                    <th>Confidence</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var qual in allQualifications)
                                {
                                    <tr class="@(qual.IsFlagged ? "table-warning" : "")">
                                        <td>
                                            @if (editingQualId == qual.Id)
                                            {
                                                <input type="text" class="form-control form-control-sm" @bind="qual.SkillName" />
                                                @if (!string.IsNullOrWhiteSpace(qual.CertificateNumber))
                                                {
                                                    <input type="text" class="form-control form-control-sm mt-1" placeholder="Cert #" @bind="qual.CertificateNumber" />
                                                }
                                            }
                                            else
                                            {
                                                <strong>@qual.SkillName</strong>
                                                @if (!string.IsNullOrWhiteSpace(qual.CertificateNumber))
                                                {
                                                    <br />
                                                    <small class="text-muted">Cert #: @qual.CertificateNumber</small>
                                                }
                                            }
                                        </td>
                                        <td>
                                            @if (editingQualId == qual.Id)
                                            {
                                                <input type="date" class="form-control form-control-sm" @bind="qual.DateAcquired" />
                                            }
                                            else
                                            {
                                                @(qual.DateAcquired?.ToString("MMM dd, yyyy") ?? "N/A")
                                            }
                                        </td>
                                        <td>
                                            @if (editingQualId == qual.Id)
                                            {
                                                <input type="date" class="form-control form-control-sm" @bind="qual.ExpirationDate" />
                                            }
                                            else
                                            {
                                                @if (qual.ExpirationDate.HasValue)
                                                {
                                                    var daysUntilExpiry = (qual.ExpirationDate.Value - DateTime.UtcNow).Days;
                                                    <span class="@GetExpiryClass(daysUntilExpiry)">
                                                        @qual.ExpirationDate.Value.ToString("MMM dd, yyyy")
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">No expiration</span>
                                                }
                                            }
                                        </td>
                                        <td>
                                            @if (editingQualId == qual.Id)
                                            {
                                                <input type="text" class="form-control form-control-sm" @bind="qual.IssuingAuthority" placeholder="Issuing Authority" />
                                            }
                                            else
                                            {
                                                @(qual.IssuingAuthority ?? "N/A")
                                            }
                                        </td>
                                        <td>
                                            <span class="badge bg-info">@((qual.ConfidenceScore * 100).ToString("F0"))%</span>
                                            @if (qual.IsFlagged)
                                            {
                                                <br /><small class="text-warning"><i class="bi bi-flag-fill"></i> Review</small>
                                            }
                                        </td>
                                        <td>
                                            @if (editingQualId == qual.Id)
                                            {
                                                <button class="btn btn-sm btn-success me-1" @onclick="() => SaveEdit(qual)">
                                                    <i class="bi bi-check-lg"></i>
                                                </button>
                                                <button class="btn btn-sm btn-secondary" @onclick="CancelEdit">
                                                    <i class="bi bi-x-lg"></i>
                                                </button>
                                            }
                                            else
                                            {
                                                <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => StartEdit(qual)" title="Edit">
                                                    <i class="bi bi-pencil"></i>
                                                </button>
                                                <button class="btn btn-sm btn-success me-1" @onclick="() => SaveSingleQualification(qual)" title="Save">
                                                    <i class="bi bi-check"></i>
                                                </button>
                                                <button class="btn btn-sm btn-outline-danger" @onclick="() => DiscardQualification(qual)" title="Discard">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <div class="mt-3 d-flex gap-2">
                        <button class="btn btn-primary" @onclick="ShowUploadZone">
                            <i class="bi bi-plus-circle"></i> Upload Another Document
                        </button>
                        <button class="btn btn-success" @onclick="SaveAllQualifications">
                            <i class="bi bi-save"></i> Save All (@allQualifications.Count)
                        </button>
                        <button class="btn btn-outline-secondary" @onclick="ResetAll">
                            <i class="bi bi-x-circle"></i> Reset All
                        </button>
                    </div>

                    <!-- Show upload zone for adding another file -->
                    @if (showUploadZone)
                    {
                        <div class="mt-4 border-top pt-4">
                            <h6 class="mb-3"><i class="bi bi-plus-circle"></i> Add Another Document</h6>
                            <div id="uploadZone2" class="upload-zone">
                                <div class="text-center py-4">
                                    <i class="bi bi-cloud-arrow-up display-4 text-primary mb-3"></i>
                                    <p class="text-muted">Supported formats: PDF, DOCX, TXT</p>
                                    
                                    <div class="mt-3">
                                        <label for="fileInput2" class="btn btn-primary btn-sm">
                                            <i class="bi bi-upload"></i> Choose File
                                        </label>
                                        <InputFile id="fileInput2" OnChange="@LoadFile" class="d-none" accept=".txt,.pdf,.docx,.doc" />
                                    </div>
                                    <p class="text-muted mt-2 mb-0 small">Or drag your file here</p>
                                    
                                    @if (!string.IsNullOrEmpty(selectedFileName))
                                    {
                                        <div class="mt-3 alert alert-info">
                                            <i class="bi bi-file-text"></i> Selected: <strong>@selectedFileName</strong>
                                            <br/>
                                            <button class="btn btn-success btn-sm mt-2" @onclick="ProcessSelectedFile">
                                                <i class="bi bi-magic"></i> Extract Qualifications
                                            </button>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                }
                else if (parseResult != null && !parseResult.Success)
                {
                    <div class="alert alert-danger">
                        <i class="bi bi-exclamation-triangle"></i> @parseResult.ErrorMessage
                    </div>
                    <button class="btn btn-secondary" @onclick="ResetAll">
                        <i class="bi bi-arrow-repeat"></i> Try Again
                    </button>
                }
                else
                {
                    <div id="uploadZone" class="upload-zone">
                        <div class="text-center py-5">
                            <i class="bi bi-cloud-arrow-up display-1 text-primary mb-3 cloud-animate"></i>
                            <h5>Upload your document</h5>
                            <p class="text-muted">Supported formats: PDF, DOCX, TXT</p>
                            
                            <div class="mt-3">
                                <label for="fileInput" class="btn btn-primary">
                                    <i class="bi bi-upload"></i> Choose File
                                </label>
                                <InputFile id="fileInput" OnChange="@LoadFile" class="d-none" accept=".txt,.pdf,.docx,.doc" />
                            </div>
                            <p class="text-muted mt-2 mb-0" style="font-size: 0.9rem;">
                                Or drag your file here
                            </p>
                            
                            @if (!string.IsNullOrEmpty(selectedFileName))
                            {
                                <div class="mt-3 alert alert-info">
                                    <i class="bi bi-file-text"></i> Selected: <strong>@selectedFileName</strong>
                                    <br/>
                                    <button class="btn btn-success mt-2" @onclick="ProcessSelectedFile">
                                        <i class="bi bi-magic"></i> Extract Qualifications
                                    </button>
                                </div>
                            }
                            
                            <div class="mt-3">
                                <small class="text-muted">
                                    Maximum file size: 10 MB<br />
                                    Your data is processed securely and not stored permanently
                                </small>
                            </div>
                            
                            <!-- LinkedIn Import Button (Mock) -->
                            <div class="mt-4 pt-3 border-top">
                                <button class="btn btn-outline-primary" @onclick="ShowLinkedInModal" title="Pre-populate qualifications from your LinkedIn profile — future feature">
                                    <i class="bi bi-linkedin"></i> Import from LinkedIn <span class="badge bg-secondary ms-1">Coming Soon</span>
                                </button>
                            </div>
                        </div>
                    </div>
                }

                @if (!string.IsNullOrWhiteSpace(errorMessage))
                {
                    <div class="alert alert-danger mt-3">
                        <i class="bi bi-x-circle-fill"></i> <strong>Something went wrong while processing.</strong> @errorMessage
                        <br /><small>Please try again or <a href="/qualifications/add" class="alert-link">enter qualifications manually</a>.</small>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <!-- Tips Section - Lighter, optional guidance -->
        <div class="card tips-card border-0 shadow-sm">
            <div class="card-header bg-light border-0">
                <h6 class="mb-0 text-muted">
                    <i class="bi bi-lightbulb text-warning"></i> Tips for Best Results
                </h6>
            </div>
            <div class="card-body bg-light">
                <ul class="list-unstyled mb-0">
                    <li class="mb-2">
                        <i class="bi bi-check2 text-success"></i> Ensure text is clearly readable
                    </li>
                    <li class="mb-2">
                        <i class="bi bi-check2 text-success"></i> Include certificate numbers when available
                    </li>
                    <li class="mb-2">
                        <i class="bi bi-check2 text-success"></i> Use high-quality scans
                    </li>
                    <li class="mb-0">
                        <i class="bi bi-check2 text-success"></i> One document at a time for best results
                    </li>
                </ul>
            </div>
        </div>
    </div>
</div>

<!-- LinkedIn Import Modal -->
@if (showLinkedInModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="bi bi-linkedin text-primary"></i> LinkedIn Integration
                    </h5>
                    <button type="button" class="btn-close" @onclick="CloseLinkedInModal"></button>
                </div>
                <div class="modal-body">
                    <div class="alert alert-info mb-3">
                        <i class="bi bi-info-circle"></i> <strong>Prototype Feature</strong>
                    </div>
                    <p>
                        This feature is not yet available in the prototype. In a future release, IMQ will support linking to your LinkedIn profile to intelligently extract qualifications.
                    </p>
                    <p class="mb-0">
                        <strong>Future capabilities will include:</strong>
                    </p>
                    <ul class="mt-2">
                        <li>OAuth-based authentication with user consent</li>
                        <li>AI-powered extraction of experience, certifications, and education</li>
                        <li>Smart validation to ensure data accuracy and relevance</li>
                    </ul>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseLinkedInModal">Close</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool isProcessing = false;
    private string? errorMessage;
    private DocumentParseResult? parseResult;
    private const long MaxFileSize = 10 * 1024 * 1024; // 10 MB
    private IBrowserFile? selectedFile;
    private string? selectedFileName;
    private byte[]? fileContent;
    
    // Multi-file support
    private List<EditableQualification> allQualifications = new();
    private List<string> processedFiles = new();
    private Guid? editingQualId = null;
    private EditableQualification? editingQualBackup = null;
    private bool showUploadZone = false;
    
    // Progressive messaging state
    private string processingMessage = "Analyzing Document";
    private string processingSubMessage = "Preparing to process...";
    private int processingProgress = 0;
    
    // LinkedIn modal state
    private bool showLinkedInModal = false;

    // Editable qualification wrapper
    public class EditableQualification
    {
        public Guid Id { get; set; } = Guid.NewGuid();
        public string SkillName { get; set; } = string.Empty;
        public string? CertificateNumber { get; set; }
        public DateTime? DateAcquired { get; set; }
        public DateTime? ExpirationDate { get; set; }
        public string? IssuingAuthority { get; set; }
        public double ConfidenceScore { get; set; }
        public bool IsFlagged { get; set; }

        public static EditableQualification FromExtracted(ExtractedQualification extracted)
        {
            var editable = new EditableQualification
            {
                SkillName = extracted.SkillName,
                CertificateNumber = extracted.CertificateNumber,
                DateAcquired = extracted.DateAcquired,
                ExpirationDate = extracted.ExpirationDate,
                IssuingAuthority = extracted.IssuingAuthority,
                ConfidenceScore = extracted.ConfidenceScore
            };

            // Flag for review if low confidence or missing key data
            editable.IsFlagged = extracted.ConfidenceScore < 0.7 || 
                                string.IsNullOrWhiteSpace(extracted.IssuingAuthority);

            return editable;
        }

        public EditableQualification Clone()
        {
            return new EditableQualification
            {
                Id = this.Id,
                SkillName = this.SkillName,
                CertificateNumber = this.CertificateNumber,
                DateAcquired = this.DateAcquired,
                ExpirationDate = this.ExpirationDate,
                IssuingAuthority = this.IssuingAuthority,
                ConfidenceScore = this.ConfidenceScore,
                IsFlagged = this.IsFlagged
            };
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JSRuntime.InvokeVoidAsync("fileUploadHelper.initialize",
                new object[] { "uploadZone", "fileInput" });
        }
    }

    private void LoadFile(InputFileChangeEventArgs e)
    {
        selectedFile = e.File;
        selectedFileName = e.File?.Name;
        errorMessage = null;
    }

    private void ShowLinkedInModal()
    {
        showLinkedInModal = true;
    }

    private void CloseLinkedInModal()
    {
        showLinkedInModal = false;
    }

    private async Task ProcessSelectedFile()
    {
        if (selectedFile == null)
        {
            errorMessage = "Please select a file first";
            return;
        }

        // Validate file size
        if (selectedFile.Size > MaxFileSize)
        {
            errorMessage = $"File size exceeds maximum allowed size of {MaxFileSize / (1024 * 1024)} MB";
            return;
        }

        // Validate file type
        var allowedExtensions = new[] { ".txt", ".pdf", ".docx", ".doc" };
        var extension = Path.GetExtension(selectedFile.Name).ToLowerInvariant();
        if (!allowedExtensions.Contains(extension))
        {
            errorMessage = "Only TXT, PDF, and DOCX files are supported";
            return;
        }

        isProcessing = true;
        errorMessage = null;

        // Start visual progress updates in background
        var progressTask = UpdateProgressMessages();

        try
        {
            // Read file into memory
            using var ms = new MemoryStream();
            using var stream = selectedFile.OpenReadStream(MaxFileSize);
            await stream.CopyToAsync(ms);
            fileContent = ms.ToArray();
            
            // Process from byte array
            using var contentStream = new MemoryStream(fileContent);
            parseResult = await DocumentParsingService.ParseDocumentAsync(contentStream, selectedFile.Name);
            
            // Wait for progress animation to complete
            await progressTask;

            // Add to accumulated qualifications (multi-file support)
            if (parseResult != null && parseResult.Success && parseResult.Qualifications.Any())
            {
                var newQualifications = parseResult.Qualifications
                    .Select(EditableQualification.FromExtracted)
                    .ToList();

                // Simple de-duplication: check for exact skill name matches
                foreach (var newQual in newQualifications)
                {
                    var isDuplicate = allQualifications.Any(existing => 
                        existing.SkillName.Equals(newQual.SkillName, StringComparison.OrdinalIgnoreCase));
                    
                    if (!isDuplicate)
                    {
                        allQualifications.Add(newQual);
                    }
                }

                // Track processed file
                if (!processedFiles.Contains(selectedFile.Name))
                {
                    processedFiles.Add(selectedFile.Name);
                }

                // Reset upload for next file
                selectedFile = null;
                selectedFileName = null;
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error processing file: {ex.Message}";
            parseResult = null;
        }
        finally
        {
            isProcessing = false;
        }
    }

    private void ShowUploadZone()
    {
        showUploadZone = !showUploadZone; // Toggle
        selectedFile = null;
        selectedFileName = null;
        errorMessage = null;
        StateHasChanged();
    }

    private void ResetAll()
    {
        parseResult = null;
        allQualifications.Clear();
        processedFiles.Clear();
        selectedFile = null;
        selectedFileName = null;
        errorMessage = null;
        StateHasChanged();
    }

    private void StartEdit(EditableQualification qual)
    {
        editingQualId = qual.Id;
        editingQualBackup = qual.Clone();
    }

    private void SaveEdit(EditableQualification qual)
    {
        editingQualId = null;
        editingQualBackup = null;
    }

    private void CancelEdit()
    {
        if (editingQualId.HasValue && editingQualBackup != null)
        {
            var qual = allQualifications.FirstOrDefault(q => q.Id == editingQualId.Value);
            if (qual != null)
            {
                var index = allQualifications.IndexOf(qual);
                allQualifications[index] = editingQualBackup;
            }
        }
        editingQualId = null;
        editingQualBackup = null;
    }

    private void DiscardQualification(EditableQualification qual)
    {
        allQualifications.Remove(qual);
    }

    private void SaveAllQualifications()
    {
        errorMessage = $"Saving {allQualifications.Count} qualification(s) (database integration pending)";
        StateHasChanged();
    }

    private void SaveSingleQualification(EditableQualification qual)
    {
        errorMessage = $"Qualification '{qual.SkillName}' will be saved (database integration pending)";
        StateHasChanged();
    }

    private int GetFlaggedCount()
    {
        return allQualifications.Count(q => q.IsFlagged);
    }

    private int GetIncompleteCount()
    {
        return allQualifications.Count(q => string.IsNullOrWhiteSpace(q.IssuingAuthority) || 
                                           (!q.DateAcquired.HasValue && !q.ExpirationDate.HasValue));
    }

    private async Task UpdateProgressMessages()
    {
        // Stage 1: Analyzing Document
        processingProgress = 33;
        processingMessage = "Analyzing Document";
        processingSubMessage = "Identifying document type and structure";
        StateHasChanged();
        await Task.Delay(1500);
        
        // Stage 2: Extracting Qualifications
        processingProgress = 66;
        processingMessage = "Extracting Qualifications";
        processingSubMessage = "Parsing skills, certifications, and training records";
        StateHasChanged();
        await Task.Delay(1500);
        
        // Stage 3: Verifying Results
        processingProgress = 100;
        processingMessage = "Verifying Results";
        processingSubMessage = "Finalizing extracted data";
        StateHasChanged();
        await Task.Delay(800);
    }

    private string GetExpiryClass(int daysUntilExpiry)
    {
        if (daysUntilExpiry < 0)
            return "text-danger fw-bold";
        if (daysUntilExpiry < 30)
            return "text-warning fw-bold";
        return "text-success";
    }

    private void SaveQualification(ExtractedQualification qualification)
    {
        // TODO: Implement saving to database
        // For now, just show a success message
        errorMessage = $"Qualification '{qualification.SkillName}' will be saved (database integration pending)";
        StateHasChanged();
    }
}
