@using IMQ.Core.Entities
@using IMQ.Core.Enums
@using IMQ.Core.Services.Read
@inject IMasterRequirementsReadService MasterRequirementsService

@page "/mrl"
@rendermode InteractiveServer

@code {
    private IReadOnlyCollection<QualificationRequirement>? _requirements;
    private bool _isLoading = true;
    private string? _error;
    private string? _selectedType;
    private string? _selectedStatus;

    protected override void OnInitialized()
    {
        LoadAllRequirements();
    }

    private void LoadAllRequirements()
    {
        _isLoading = true;
        _error = null;
        
        try
        {
            _requirements = MasterRequirementsService.GetAll();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void OnTypeFilterChanged(ChangeEventArgs e)
    {
        _selectedType = e.Value?.ToString();
        
        if (string.IsNullOrEmpty(_selectedType))
        {
            LoadAllRequirements();
            return;
        }

        _isLoading = true;
        _error = null;
        
        try
        {
            if (Enum.TryParse<RequirementType>(_selectedType, out var type))
            {
                _requirements = MasterRequirementsService.GetByType(type);
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void OnStatusFilterChanged(ChangeEventArgs e)
    {
        _selectedStatus = e.Value?.ToString();
        
        if (string.IsNullOrEmpty(_selectedStatus))
        {
            LoadAllRequirements();
            return;
        }

        _isLoading = true;
        _error = null;
        
        try
        {
            if (Enum.TryParse<RequirementApprovalStatus>(_selectedStatus, out var status))
            {
                _requirements = MasterRequirementsService.GetByApprovalStatus(status);
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _isLoading = false;
        }
    }
}

<div class="mb-4">
    <h3 class="mb-3">Master Requirements List</h3>
    
    <div class="alert alert-info mb-3" role="alert">
        <strong>What is this?</strong>
        <p class="mb-0 mt-2">
            The Master Requirements List defines the approved, audit-ready expectations used across Jobs, Qualifications, and Assessments. 
            It serves as a single source of truth, preventing inconsistencies and ensuring compliance across your organization.
        </p>
    </div>
</div>

<div class="d-flex justify-content-between align-items-center mb-3">
    <span class="text-muted small">
        Read-only view. Requirements are managed by authorized administrators.
    </span>

    <button class="btn btn-sm btn-outline-secondary" disabled>
        + New Requirement
    </button>
</div>

<hr />

@if (_isLoading)
{
    <div class="text-muted fst-italic">
        Loading master requirements…
    </div>
}
else if (!string.IsNullOrEmpty(_error))
{
    <div class="alert alert-danger">
        <strong>Error loading requirements:</strong><br />
        @_error
    </div>
}
else if (_requirements == null || !_requirements.Any())
{
    <div class="alert alert-secondary">
        No requirements found.
    </div>
}
else
{
    <div class="row mb-3">
        <div class="col-md-4">
            <label class="form-label">Requirement Type</label>
            <select class="form-select" value="@_selectedType" @onchange="OnTypeFilterChanged">
                <option value="">Show All</option>
                <option value="Education">Education</option>
                <option value="Training">Training</option>
                <option value="Experience">Experience</option>
                <option value="Certification">Certification</option>
            </select>
        </div>

        <div class="col-md-4">
            <label class="form-label">Approval Status</label>
            <select class="form-select" value="@_selectedStatus" @onchange="OnStatusFilterChanged">
                <option value="">Show All</option>
                <option value="Draft">Draft</option>
                <option value="Approved">Approved</option>
                <option value="Retired">Retired</option>
            </select>
        </div>
    </div>

    <p class="text-muted">
        <strong>@_requirements.Count()</strong> requirement@(_requirements.Count() != 1 ? "s" : "") loaded.
    </p>

    <div class="list-group">
        @foreach (var req in _requirements)
        {
            <div class="list-group-item">
                <div class="fw-semibold">@req.Name</div>

                <div class="small text-muted">
                    @req.RequirementType —
                    @req.RequirementLevel —
                    @req.RequirementApprovalStatus
                </div>
            </div>
        }
    </div>


}
