@page "/compliance-check"
@using IMQ.Core.Interfaces
@using IMQ.Core.Enums
@inject IComplianceCalculationService ComplianceService
@rendermode InteractiveServer

<PageTitle>Compliance Check - IMQ</PageTitle>

<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-12">
            <h2 class="mb-4">
                <i class="bi bi-check-circle"></i> Real-Time Compliance Checker
            </h2>
            <p class="text-muted">Instantly match worker qualifications against job requirements</p>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-body text-center py-5">
                    <i class="bi bi-clipboard-data" style="font-size: 3rem; color: #6c757d;"></i>
                    <p class="mt-3 text-muted">Real-time compliance calculation feature implemented!</p>
                    <p class="text-muted">Service layer complete. UI coming soon.</p>
                </div>
            </div>
        </div>
    </div>
</div>
