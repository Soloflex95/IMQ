@page "/compliance-check"
@using IMQ.Core.Interfaces
@using IMQ.Core.Enums
@inject IComplianceCalculationService ComplianceService
@rendermode InteractiveServer

<PageTitle>Compliance Check - IMQ</PageTitle>

<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-12">
            <h2 class="mb-4">
                <i class="bi bi-check-circle"></i> Real-Time Compliance Checker
            </h2>
            <p class="text-muted">Instantly match worker qualifications against job requirements</p>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">Select Worker & Job</h5>
                    
                    <div class="mb-3">
                        <label for="workerSelect" class="form-label">Worker</label>
                        <select class="form-select" id="workerSelect" @bind="selectedWorkerId">
                            <option value="">-- Select Worker --</option>
                            @foreach (var worker in mockWorkers)
                            {
                                <option value="@worker.Id">@worker.Name (@worker.Role)</option>
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label for="jobSelect" class="form-label">Job/Role</label>
                        <select class="form-select" id="jobSelect" @bind="selectedJobId">
                            <option value="">-- Select Job --</option>
                            @foreach (var job in mockJobs)
                            {
                                <option value="@job.Id">@job.Title</option>
                            }
                        </select>
                    </div>

                    <button class="btn btn-primary w-100" @onclick="CalculateCompliance" disabled="@(!CanCalculate)">
                        <i class="bi bi-calculator"></i> Calculate Compliance
                    </button>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            @if (complianceResult != null)
            {
                <div class="card shadow-sm">
                    <div class="card-header @GetStatusCardClass()">
                        <h5 class="mb-0">
                            <i class="bi @GetStatusIcon()"></i> 
                            Compliance Status: @complianceResult.Status
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="row mb-3">
                            <div class="col-6">
                                <div class="text-center p-3 bg-light rounded">
                                    <h2 class="mb-0">@complianceResult.CompliancePercentage%</h2>
                                    <small class="text-muted">Overall Compliance</small>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="text-center p-3 bg-light rounded">
                                    <h2 class="mb-0">@complianceResult.QualifiedCount / @complianceResult.TotalRequirements</h2>
                                    <small class="text-muted">Requirements Met</small>
                                </div>
                            </div>
                        </div>

                        @if (complianceResult.MissingRequirements.Any())
                        {
                            <div class="alert alert-danger">
                                <h6 class="alert-heading">
                                    <i class="bi bi-exclamation-triangle"></i> Missing Requirements
                                </h6>
                                <ul class="mb-0">
                                    @foreach (var missing in complianceResult.MissingRequirements)
                                    {
                                        <li>@missing</li>
                                    }
                                </ul>
                            </div>
                        }

                        @if (complianceResult.ExpiredQualifications.Any())
                        {
                            <div class="alert alert-warning">
                                <h6 class="alert-heading">
                                    <i class="bi bi-clock-history"></i> Expired/Expiring Soon
                                </h6>
                                <ul class="mb-0">
                                    @foreach (var expired in complianceResult.ExpiredQualifications)
                                    {
                                        <li>@expired</li>
                                    }
                                </ul>
                            </div>
                        }

                        @if (complianceResult.IsCompliant)
                        {
                            <div class="alert alert-success">
                                <i class="bi bi-check-circle-fill"></i> 
                                Worker is fully compliant for this role
                            </div>
                        }
                    </div>
                </div>
            }
            else if (isCalculating)
            {
                <div class="card shadow-sm">
                    <div class="card-body text-center py-5">
                        <div class="spinner-border text-primary" role="status">
                            <span class="visually-hidden">Calculating...</span>
                        </div>
                        <p class="mt-3 text-muted">Analyzing qualifications...</p>
                    </div>
                </div>
            }
            else
            {
                <div class="card shadow-sm">
                    <div class="card-body text-center py-5">
                        <i class="bi bi-clipboard-data" style="font-size: 3rem; color: #ccc;"></i>
                        <p class="mt-3 text-muted">Select a worker and job to check compliance</p>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private string? selectedWorkerId;
    private string? selectedJobId;
    private ComplianceResult? complianceResult;
    private bool isCalculating;
    private List<MockWorker> mockWorkers = new();
    private List<MockJob> mockJobs = new();

    protected override void OnInitialized()
    {
        mockWorkers = new List<MockWorker>
        {
            new MockWorker { Id = Guid.NewGuid(), Name = "Sarah Johnson", Role = "Manufacturing Operator" },
            new MockWorker { Id = Guid.NewGuid(), Name = "Michael Chen", Role = "QA Inspector" },
            new MockWorker { Id = Guid.NewGuid(), Name = "Emily Rodriguez", Role = "Packaging Technician" },
            new MockWorker { Id = Guid.NewGuid(), Name = "David Kim", Role = "Laboratory Technician" },
            new MockWorker { Id = Guid.NewGuid(), Name = "Jessica Williams", Role = "Production Supervisor" }
        };

        mockJobs = new List<MockJob>
        {
            new MockJob { Id = Guid.NewGuid(), Title = "Manufacturing Operator - Line A" },
            new MockJob { Id = Guid.NewGuid(), Title = "QA Inspector - Sterile Products" },
            new MockJob { Id = Guid.NewGuid(), Title = "Packaging Technician - Labeling" },
            new MockJob { Id = Guid.NewGuid(), Title = "Laboratory Technician - Microbiology" },
            new MockJob { Id = Guid.NewGuid(), Title = "Production Supervisor - Fill/Finish" }
        };
    }

    private bool CanCalculate => !string.IsNullOrEmpty(selectedWorkerId) && !string.IsNullOrEmpty(selectedJobId);

    private async Task CalculateCompliance()
    {
        if (!CanCalculate) return;

        isCalculating = true;
        complianceResult = null;

        try
        {
            await Task.Delay(500);
            complianceResult = await ComplianceService.CalculateComplianceAsync(
                Guid.Parse(selectedWorkerId!),
                Guid.Parse(selectedJobId!)
            );
        }
        finally
        {
            isCalculating = false;
        }
    }

    private string GetStatusCardClass()
    {
        if (complianceResult == null) return "bg-light";
        return complianceResult.Status switch
        {
            ComplianceStatus.Qualified => "bg-success text-white",
            ComplianceStatus.Expired => "bg-warning text-dark",
            ComplianceStatus.GapDetected => "bg-danger text-white",
            _ => "bg-light"
        };
    }

    private string GetStatusIcon()
    {
        if (complianceResult == null) return "bi-question-circle";
        return complianceResult.Status switch
        {
            ComplianceStatus.Qualified => "bi-check-circle-fill",
            ComplianceStatus.Expired => "bi-clock-history",
            ComplianceStatus.GapDetected => "bi-exclamation-triangle-fill",
            _ => "bi-question-circle"
        };
    }

    private class MockWorker
    {
        public Guid Id { get; set; }
        public string Name { get; set; } = string.Empty;
        public string Role { get; set; } = string.Empty;
    }

    private class MockJob
    {
        public Guid Id { get; set; }
        public string Title { get; set; } = string.Empty;
    }
}
