            new() { Id = Guid.NewGuid(), Title = "Quality Assurance Specialist", Department = "Quality Control", MinYearsExperience = 3, RequirementCount = 8, AssignedWorkerCount = 12, QualifiedPercentage = 85, IsCritical = true },
            new() { Id = Guid.NewGuid(), Title = "GMP Auditor", Department = "Compliance", MinYearsExperience = 5, RequirementCount = 10, AssignedWorkerCount = 6, QualifiedPercentage = 92, IsCritical = true },
            new() { Id = Guid.NewGuid(), Title = "Manufacturing Technician", Department = "Production", MinYearsExperience = 2, RequirementCount = 6, AssignedWorkerCount = 24, QualifiedPercentage = 78, IsCritical = false },
            new() { Id = Guid.NewGuid(), Title = "Validation Engineer", Department = "Engineering", MinYearsExperience = 4, RequirementCount = 12, AssignedWorkerCount = 8, QualifiedPercentage = 88, IsCritical = true },
            new() { Id = Guid.NewGuid(), Title = "Laboratory Analyst", Department = "QC Lab", MinYearsExperience = 2, RequirementCount = 7, AssignedWorkerCount = 15, QualifiedPercentage = 95, IsCritical = false },
            new() { Id = Guid.NewGuid(), Title = "SOP Writer", Department = "Documentation", MinYearsExperience = 3, RequirementCount = 5, AssignedWorkerCount = 4, QualifiedPercentage = 75, IsCritical = false },
            new() { Id = Guid.NewGuid(), Title = "Production Supervisor", Department = "Production", MinYearsExperience = 5, RequirementCount = 9, AssignedWorkerCount = 10, QualifiedPercentage = 80, IsCritical = true },
            new() { Id = Guid.NewGuid(), Title = "Quality Control Technician", Department = "Quality Control", MinYearsExperience = 1, RequirementCount = 6, AssignedWorkerCount = 18, QualifiedPercentage = 72, IsCritical = false },
            new() { Id = Guid.NewGuid(), Title = "Compliance Officer", Department = "Compliance", MinYearsExperience = 4, RequirementCount = 11, AssignedWorkerCount = 5, QualifiedPercentage = 100, IsCritical = true },
            new() { Id = Guid.NewGuid(), Title = "Process Engineer", Department = "Engineering", MinYearsExperience = 3, RequirementCount = 10, AssignedWorkerCount = 7, QualifiedPercentage = 86, IsCritical = false },
            new() { Id = Guid.NewGuid(), Title = "Batch Record Reviewer", Department = "Quality Assurance", MinYearsExperience = 2, RequirementCount = 5, AssignedWorkerCount = 9, QualifiedPercentage = 89, IsCritical = false },
            new() { Id = Guid.NewGuid(), Title = "Equipment Qualification Specialist", Department = "Validation", MinYearsExperience = 4, RequirementCount = 13, AssignedWorkerCount = 6, QualifiedPercentage = 83, IsCritical = true }
        };
    }

    private void ViewJobDetails(Guid jobId)
    {
        selectedJob = new JobDetailViewModel
        {
            Id = jobId,
            Title = "Quality Assurance Specialist",
            Requirements = new List<JobRequirementViewModel>
            {
                new() { SkillName = "Aseptic Technique Level 2", IsRequired = true, MinLevel = 3 },
                new() { SkillName = "GMP Knowledge", IsRequired = true, MinLevel = 4 },
                new() { SkillName = "Quality Control Testing", IsRequired = true, MinLevel = 3 },
                new() { SkillName = "SOP Documentation", IsRequired = false, MinLevel = 2 }
            },
            Workers = new List<WorkerAssignmentViewModel>
            {
                new() { Name = "John Smith", Email = "john.smith@company.com", QualificationStatus = "Qualified" },
                new() { Name = "Jane Doe", Email = "jane.doe@company.com", QualificationStatus = "Qualified" },
                new() { Name = "Mike Johnson", Email = "mike.johnson@company.com", QualificationStatus = "Needs Review" }
            }
        };
    }

    private void CreateJob() => Console.WriteLine("Create Job clicked");
    private void EditJob(Guid id) => Console.WriteLine($"Edit Job {id} clicked");
    private void CloseDetails() => selectedJob = null;

    private string GetQualificationBadgeClass(string status) => status switch
    {
        "Qualified" => "bg-success",
        "Needs Review" => "bg-warning text-dark",
        "Not Qualified" => "bg-danger",
        _ => "bg-secondary"
    };

    private class JobViewModel
    {
        public Guid Id { get; set; }
        public string Title { get; set; } = string.Empty;
        public string Department { get; set; } = string.Empty;
        public int MinYearsExperience { get; set; }
        public int RequirementCount { get; set; }
        public int AssignedWorkerCount { get; set; }
        public int QualifiedPercentage { get; set; }
        public bool IsCritical { get; set; }
    }

    private class JobDetailViewModel
    {
        public Guid Id { get; set; }
        public string Title { get; set; } = string.Empty;
        public List<JobRequirementViewModel> Requirements { get; set; } = new();
        public List<WorkerAssignmentViewModel> Workers { get; set; } = new();
    }

    private class JobRequirementViewModel
    {
        public string SkillName { get; set; } = string.Empty;
        public bool IsRequired { get; set; }
        public int? MinLevel { get; set; }
    }

    private class WorkerAssignmentViewModel
    {
        public string Name { get; set; } = string.Empty;
        public string Email { get; set; } = string.Empty;
        public string QualificationStatus { get; set; } = string.Empty;
    }
}
