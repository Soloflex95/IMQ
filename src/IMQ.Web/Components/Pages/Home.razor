@page "/"
@rendermode InteractiveServer

<PageTitle>IMQ Dashboard</PageTitle>

<div class="mb-3">
    <div class="d-flex flex-column flex-md-row justify-content-md-between align-items-md-center gap-3">
        <div>
            <h1><i class="bi bi-speedometer2"></i> Dashboard</h1>
            <p class="lead text-muted mb-0">Track, assess, and prove worker qualifications in regulated environments.</p>
        </div>
        <div class="d-flex flex-column gap-2 align-items-end">
            <div>
                <span class="badge bg-info fs-6"><i class="bi bi-person-badge"></i> Viewing: My Team</span>
            </div>
            <div class="d-flex align-items-center gap-2">
                <label class="fw-semibold mb-0 small">Scope:</label>
                <select class="form-select form-select-sm" style="width: 140px;" @bind="selectedScope">
                    <option value="MyTeam">My Team</option>
                    <option value="MyOrg">My Org</option>
                    <option value="AllUsers">All Users</option>
                </select>
            </div>
        </div>
    </div>
</div>

<div class="row mt-4">
    <div class="col-md-3">
        <a href="/workers?status=Qualified" class="text-decoration-none">
            <div class="card text-white bg-success mb-3 dashboard-card" 
                 data-bs-toggle="tooltip" 
                 data-bs-placement="top" 
                 title="Workers who meet all assigned job requirements">
                <div class="card-body text-center">
                    <i class="bi bi-check-circle display-1"></i>
                    <h2 class="mt-3">24</h2>
                    <p>Qualified Workers</p>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-3">
        <a href="/workers?status=Needs Review" class="text-decoration-none">
            <div class="card text-white bg-warning mb-3 dashboard-card" 
                 data-bs-toggle="tooltip" 
                 data-bs-placement="top" 
                 title="Workers missing recent qualifications or nearing expiration">
                <div class="card-body text-center">
                    <i class="bi bi-exclamation-triangle display-1"></i>
                    <h2 class="mt-3">8</h2>
                    <p>Needs Review</p>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-3">
        <a href="/workers?status=Not Qualified" class="text-decoration-none">
            <div class="card text-white bg-danger mb-3 dashboard-card" 
                 data-bs-toggle="tooltip" 
                 data-bs-placement="top" 
                 title="Workers missing critical skills or expired credentials">
                <div class="card-body text-center">
                    <i class="bi bi-x-circle display-1"></i>
                    <h2 class="mt-3">3</h2>
                    <p>Not Qualified</p>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-3">
        <a href="/jobs" class="text-decoration-none">
            <div class="card text-white mb-3 dashboard-card" 
                 style="background-color: #7DB9DE;" 
                 data-bs-toggle="tooltip" 
                 data-bs-placement="top" 
                 title="Roles with at least one worker assigned">
                <div class="card-body text-center">
                    <i class="bi bi-briefcase display-1"></i>
                    <h2 class="mt-3">12</h2>
                    <p>Active Jobs</p>
                </div>
            </div>
        </a>
    </div>
</div>

<div class="row mt-4">
    <div class="col-md-6 mb-3">
        <div class="card h-100">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0"><i class="bi bi-lightning"></i> Quick Actions</h5>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-6">
                        <a href="/qualifications" class="text-decoration-none">
                            <div class="card h-100 quick-action-card">
                                <div class="card-body text-center">
                                    <i class="bi bi-award d-block display-4 text-primary mb-3"></i>
                                    <h6 class="card-title fw-bold">My Qualifications</h6>
                                    <p class="card-text small text-muted">See your current certifications, skills, and qualification status</p>
                                </div>
                            </div>
                        </a>
                    </div>
                    <div class="col-6">
                        <a href="/workers" class="text-decoration-none">
                            <div class="card h-100 quick-action-card">
                                <div class="card-body text-center">
                                    <i class="bi bi-people-fill d-block display-4 text-primary mb-3"></i>
                                    <h6 class="card-title fw-bold">Manage Team</h6>
                                    <p class="card-text small text-muted">Assign roles, review staff readiness, track gaps</p>
                                </div>
                            </div>
                        </a>
                    </div>
                    <div class="col-6">
                        <a href="/jobs" class="text-decoration-none">
                            <div class="card h-100 quick-action-card">
                                <div class="card-body text-center">
                                    <i class="bi bi-briefcase-fill d-block display-4 text-primary mb-3"></i>
                                    <h6 class="card-title fw-bold">Job Roles</h6>
                                    <p class="card-text small text-muted">View available roles and their qualification requirements</p>
                                </div>
                            </div>
                        </a>
                    </div>
                    <div class="col-6">
                        <a href="/assessments" class="text-decoration-none">
                            <div class="card h-100 quick-action-card">
                                <div class="card-body text-center">
                                    <i class="bi bi-clipboard-check-fill d-block display-4 text-primary mb-3"></i>
                                    <h6 class="card-title fw-bold">Assessments</h6>
                                    <p class="card-text small text-muted">Match team qualifications against job needs</p>
                                </div>
                            </div>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-6 mb-3">
        <div class="card h-100">
            <div class="card-header bg-secondary text-white">
                <h5 class="mb-0"><i class="bi bi-clock-history"></i> Recent Activity</h5>
            </div>
            <div class="card-body">
                <div class="list-group">
                    <div class="list-group-item">
                        <small class="text-muted"><i class="bi bi-clipboard-check"></i> 2h ago</small>
                        <p class="mb-0">Jane Doe assessed for Quality Specialist - Qualified</p>
                    </div>
                    <div class="list-group-item">
                        <small class="text-muted"><i class="bi bi-check-circle"></i> 5h ago</small>
                        <p class="mb-0">Override approved for Mike Johnson - QA Lead</p>
                    </div>
                    <div class="list-group-item">
                        <small class="text-muted"><i class="bi bi-file-earmark-arrow-up"></i> 1d ago</small>
                        <p class="mb-0">New CV uploaded and parsed successfully</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private string selectedScope = "MyTeam";
}
