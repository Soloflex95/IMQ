@page "/"
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>IMQ Dashboard</PageTitle>

<div class="mb-3">
    <div class="d-flex flex-column flex-md-row justify-content-md-between align-items-md-center gap-3">
        <div>
            <h1><i class="bi bi-speedometer2"></i> Dashboard</h1>
            <p class="lead text-muted mb-0">Track, assess, and prove worker qualifications in regulated environments.</p>
        </div>
        <div class="d-flex flex-column gap-2 align-items-end">
            <div>
                <span class="badge bg-info fs-6">🧑‍💼 Viewing: My Team</span>
            </div>
            <div class="d-flex align-items-center gap-2">
                <span class="badge bg-light text-dark border" style="cursor: not-allowed;" title="Scope switching isn’t enabled in this demo build.">Scope: My Team</span>
            </div>
        </div>
    </div>
</div>

<a href="/compliance-alerts" class="alert alert-warning d-flex align-items-center justify-content-between mb-3 compliance-alert text-decoration-none text-dark" role="button">
    <div>
        <i class="bi bi-exclamation-triangle-fill me-2 fs-5"></i>
        <strong><span class="fw-bolder">3</span> unresolved compliance alerts</strong>
    </div>
    <i class="bi bi-chevron-right"></i>
</a>

<div class="row mt-4">
    <div class="col-md-3">
        <a href="/workers?status=Qualified" class="text-decoration-none">
            <div class="card text-white bg-success mb-3 dashboard-card" 
                 data-bs-toggle="tooltip" 
                 data-bs-placement="top" 
                 title="Workers who meet all assigned job requirements">
                <div class="card-body text-center">
                    <i class="bi bi-check-circle display-1"></i>
                    <h2 class="mt-3">24</h2>
                    <p class="fw-bold fs-5 mb-1">Qualified Workers</p>
                    <small class="d-block">Fully authorized for assigned roles.</small>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-3">
        <a href="/workers?status=Needs Review" class="text-decoration-none">
            <div class="card text-white bg-warning mb-3 dashboard-card" 
                 data-bs-toggle="tooltip" 
                 data-bs-placement="top" 
                 title="Workers missing recent qualifications or nearing expiration">
                <div class="card-body text-center">
                    <i class="bi bi-exclamation-triangle display-1"></i>
                    <h2 class="mt-3">8</h2>
                    <p class="fw-bold fs-5 mb-1">Needs Review</p>
                    <small class="d-block text-dark fw-semibold">Gaps detected—review required.</small>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-3">
        <a href="/workers?status=Not Qualified" class="text-decoration-none">
            <div class="card text-white bg-danger mb-3 dashboard-card" 
                 data-bs-toggle="tooltip" 
                 data-bs-placement="top" 
                 title="Workers missing critical skills or expired credentials">
                <div class="card-body text-center">
                    <i class="bi bi-x-circle display-1"></i>
                    <h2 class="mt-3">3</h2>
                    <p class="fw-bold fs-5 mb-1">Not Qualified</p>
                    <small class="d-block">Authorization blocked by unmet criteria.</small>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-3">
        <a href="/jobs" class="text-decoration-none">
            <div class="card text-white mb-3 dashboard-card" 
                 style="background-color: #7DB9DE;" 
                 data-bs-toggle="tooltip" 
                 data-bs-placement="top" 
                 title="Roles with at least one worker assigned">
                <div class="card-body text-center">
                    <i class="bi bi-briefcase display-1"></i>
                    <h2 class="mt-3">12</h2>
                    <p class="fw-bold fs-5 mb-1">Active Jobs</p>
                    <small class="d-block">Roles currently active in your scope.</small>
                </div>
            </div>
        </a>
    </div>
</div>

<div class="row mt-4">
    <div class="col-md-6 mb-3">
        <div class="card h-100">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0"><i class="bi bi-lightning"></i> Quick Actions</h5>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-6">
                        <div class="card h-100 quick-action-card" @onclick="ShowUploadCVPlaceholder">
                            <div class="card-body text-center">
                                <i class="bi bi-cloud-upload-fill d-block display-4 text-primary mb-3"></i>
                                <h6 class="card-title fw-bold">Upload Your Qualification Evidence</h6>
                                <p class="card-text small text-muted">Upload resumes, certificates, or training records to update your qualification record.</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="card h-100 quick-action-card" @onclick="ShowAddQualificationPlaceholder">
                            <div class="card-body text-center">
                                <i class="bi bi-plus-circle-fill d-block display-4 text-primary mb-3"></i>
                                <h6 class="card-title fw-bold">Add Qualification</h6>
                                <p class="card-text small text-muted">Manually enter a new qualification</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="card h-100 quick-action-card" @onclick="ShowAssignRolePlaceholder">
                            <div class="card-body text-center">
                                <i class="bi bi-person-badge-fill d-block display-4 text-primary mb-3"></i>
                                <h6 class="card-title fw-bold">Review Team Assessments</h6>
                                <p class="card-text small text-muted">Review current assessment outcomes for your team.</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="card h-100 quick-action-card" @onclick="ShowComplianceCheckPlaceholder">
                            <div class="card-body text-center">
                                <i class="bi bi-arrow-left-right d-block display-4 text-primary mb-3"></i>
                                <h6 class="card-title fw-bold">Evaluate Role Alignment</h6>
                                <p class="card-text small text-muted">Assess worker fit for alternative roles.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-6 mb-3">
        <div class="card h-100">
            <div class="card-header bg-secondary text-white">
                <h5 class="mb-0"><i class="bi bi-lightning-charge-fill"></i> System Updates (AI + Activity)</h5>
            </div>
            <div class="card-body">
                <!-- AI-Generated Recommendations Section -->
                <div class="ai-recommendations mb-3">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <h6 class="mb-0">
                            <i class="bi bi-brain"></i> Recommended Actions (AI)
                        </h6>
                        <button class="btn btn-sm btn-outline-secondary" disabled title="Placeholder - not yet functional">
                            <i class="bi bi-arrow-clockwise"></i> Refresh
                        </button>
                    </div>
                    <small class="text-muted d-block mb-2" title="These recommendations are based on recent user activity and qualification data.">
                        <i class="bi bi-brain"></i> AI-Generated | Last Updated: @DateTime.Now.ToString("h:mm tt")
                    </small>
                    <ul class="list-unstyled mb-0">
                        <li class="mb-2">
                            <i class="bi bi-exclamation-triangle-fill text-warning"></i> 
                            <strong>3</strong> workers lack current job assignments
                        </li>
                        <li class="mb-2">
                            <i class="bi bi-flag-fill text-info"></i> 
                            <strong>2</strong> assessments flagged for override review
                        </li>
                        <li class="mb-2">
                            <i class="bi bi-calendar-x-fill text-danger"></i> 
                            <strong>1</strong> cert expiring in next 7 days (Mike J.)
                        </li>
                    </ul>
                </div>

                <hr class="my-3" />

                <!-- Recent Activity Section -->
                <div class="recent-activity">
                    <h6 class="mb-3"><i class="bi bi-clock-history"></i> Recent Activity</h6>
                    <div class="list-group list-group-flush">
                        <div class="list-group-item px-0">
                            <small class="text-muted">
                                <i class="bi bi-clipboard-check"></i> 2h ago 
                                <span class="timestamp-absolute">• @GetAbsoluteTimestamp(DateTime.UtcNow.AddHours(-2))</span>
                            </small>
                            <p class="mb-0">Jane Doe assessed for Quality Specialist - Qualified</p>
                        </div>
                        <div class="list-group-item px-0">
                            <small class="text-muted">
                                <i class="bi bi-check-circle"></i> 5h ago 
                                <span class="timestamp-absolute">• @GetAbsoluteTimestamp(DateTime.UtcNow.AddHours(-5))</span>
                            </small>
                            <p class="mb-0">Override approved for Mike Johnson - QA Lead</p>
                        </div>
                        <div class="list-group-item px-0">
                            <small class="text-muted">
                                <i class="bi bi-file-earmark-arrow-up"></i> 1d ago 
                                <span class="timestamp-absolute">• @GetAbsoluteTimestamp(DateTime.UtcNow.AddDays(-1))</span>
                            </small>
                            <p class="mb-0">New CV uploaded and parsed successfully</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private string selectedScope = "MyTeam";

    private void ShowUploadCVPlaceholder()
    {
        Navigation.NavigateTo("/upload-qualifications");
    }

    private void ShowAddQualificationPlaceholder()
    {
        Navigation.NavigateTo("/qualifications/add");
    }

    private void ShowAssignRolePlaceholder()
    {
        // TODO: Open Assign Role modal
        Console.WriteLine("Assign Role action triggered");
    }

    private void ShowComplianceCheckPlaceholder()
    {
        Navigation.NavigateTo("/compliance-check");
    }

    private string GetAbsoluteTimestamp(DateTime utcTime)
    {
        // Convert UTC to local time
        var localTime = TimeZoneInfo.ConvertTimeFromUtc(utcTime, TimeZoneInfo.Local);
        
        // Get time zone abbreviation
        var timeZone = TimeZoneInfo.Local;
        var isDaylightSaving = timeZone.IsDaylightSavingTime(localTime);
        var tzAbbreviation = isDaylightSaving ? timeZone.DaylightName : timeZone.StandardName;
        
        // Simplify common time zones
        if (tzAbbreviation.Contains("Eastern"))
            tzAbbreviation = isDaylightSaving ? "EDT" : "EST";
        else if (tzAbbreviation.Contains("Central"))
            tzAbbreviation = isDaylightSaving ? "CDT" : "CST";
        else if (tzAbbreviation.Contains("Mountain"))
            tzAbbreviation = isDaylightSaving ? "MDT" : "MST";
        else if (tzAbbreviation.Contains("Pacific"))
            tzAbbreviation = isDaylightSaving ? "PDT" : "PST";
        else if (timeZone.Id == "UTC")
            tzAbbreviation = "UTC";
        else
        {
            // Format UTC offset for other time zones
            var offset = timeZone.GetUtcOffset(localTime);
            var sign = offset >= TimeSpan.Zero ? "+" : "-";
            var hours = Math.Abs(offset.Hours);
            tzAbbreviation = $"UTC{sign}{hours}";
        }
        
        // Format: "3:45 PM EDT" or "Jul 23, 9:12 AM UTC"
        var today = DateTime.Today;
        if (localTime.Date == today)
        {
            // Same day: show time only
            return $"{localTime:h:mm tt} {tzAbbreviation}";
        }
        else
        {
            // Different day: show date and time
            return $"{localTime:MMM d, h:mm tt} {tzAbbreviation}";
        }
    }
}
