@page "/workers/{workerId}/qualification-record"
@namespace IMQ.Web.Components.Pages.WorkerRecords
@using IMQ.Core.Entities
@using IMQ.Core.Interfaces
@using IMQ.Core.Enums
@using QualificationRecordModel = IMQ.Core.Entities.QualificationRecord
@inject IQualificationRecordService QualificationRecordService
@rendermode InteractiveServer

<PageTitle>Structured Qualification Record - IMQ</PageTitle>

<div class="mb-3">
    <a href="/workers" class="small">&larr; Back to Workers</a>
</div>

<h1>Structured Qualification Record</h1>
<p class="lead">IMQ organizes training, certifications, skills, and experience into a standardized record so qualifications can be evaluated consistently.</p>

@if (_record is null)
{
    <div class="alert alert-info" role="alert">
        Loading qualification record...
    </div>
}
else if (string.IsNullOrWhiteSpace(_record.WorkerId))
{
    <div class="alert alert-warning" role="alert">
        Worker record not found for "@workerId".
        <a class="ms-2" href="/workers">Return to Workers</a>
    </div>
}
else
{
    <div class="card mb-4">
        <div class="card-body">
            <div class="row g-3 align-items-center">
                <div class="col-md-4">
                    <div class="small text-muted">Worker Name</div>
                    <div class="fw-semibold">@_record.WorkerName</div>
                </div>
                <div class="col-md-2">
                    <div class="small text-muted">Role</div>
                    <div class="fw-semibold">@_record.Role</div>
                </div>
                <div class="col-md-2">
                    <div class="small text-muted">Qualification Status</div>
                    <span class="badge @GetStatusBadgeClass(_record.QualificationStatus)">@_record.QualificationStatus</span>
                </div>
                <div class="col-md-2">
                    <div class="small text-muted">Mandatory Coverage</div>
                    <div class="fw-semibold">@_record.MetMandatoryRequirements/@_record.TotalMandatoryRequirements</div>
                </div>
                <div class="col-md-2">
                    <div class="small text-muted">Supporting Coverage</div>
                    <div class="fw-semibold">@_record.MetSupportingRequirements/@_record.TotalSupportingRequirements</div>
                </div>
            </div>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header"><strong>Decision Statement</strong></div>
        <div class="card-body">
            <p class="mb-0">@GetDecisionStatement(_record)</p>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header"><strong>Role Requirements</strong></div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Requirement</th>
                            <th>Type</th>
                            <th>Status</th>
                            <th>Gap</th>
                            <th>Evidence</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var requirement in _record.RoleRequirements)
                        {
                            <tr class="@(requirement.IsMet ? string.Empty : "table-danger")">
                                <td>@requirement.RequirementName</td>
                                <td>@requirement.RequirementType</td>
                                <td>
                                    <span class="fw-semibold @(requirement.IsMet ? "text-success" : "text-danger")">@requirement.Status</span>
                                </td>
                                <td>
                                    <span class="badge @(!requirement.IsMet ? "bg-danger" : "bg-secondary")">@(!requirement.IsMet ? "Yes" : "No")</span>
                                </td>
                                <td>@GetRequirementEvidenceDisplay(requirement)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header"><strong>Qualification Gaps</strong></div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6 mb-3 mb-md-0">
                    <h6 class="text-danger">Mandatory Gaps (blocking)</h6>
                    @if (_mandatoryGaps.Count == 0)
                    {
                        <div class="text-success small">None</div>
                    }
                    else
                    {
                        <ul class="mb-0">
                            @foreach (var requirement in _mandatoryGaps)
                            {
                                <li>@requirement.RequirementName</li>
                            }
                        </ul>
                    }
                </div>
                <div class="col-md-6">
                    <h6 class="text-warning">Supporting Gaps (non-blocking)</h6>
                    @if (_supportingGaps.Count == 0)
                    {
                        <div class="text-success small">None</div>
                    }
                    else
                    {
                        <ul class="mb-0">
                            @foreach (var requirement in _supportingGaps)
                            {
                                <li>@requirement.RequirementName</li>
                            }
                        </ul>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header"><strong>Certifications</strong></div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped mb-0">
                    <thead>
                        <tr>
                            <th>Certification</th>
                            <th>Issuer</th>
                            <th>Date Acquired</th>
                            <th>Expiration Date</th>
                            <th>Status</th>
                            <th>Evidence Source</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var cert in _record.Certifications)
                        {
                            <tr>
                                <td>@cert.CertificationName</td>
                                <td>@cert.Issuer</td>
                                <td>@FormatDate(cert.DateAcquired)</td>
                                <td>@(cert.ExpirationDate.HasValue ? FormatDate(cert.ExpirationDate.Value) : "N/A")</td>
                                <td>@cert.Status</td>
                                <td>@cert.EvidenceSource</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header"><strong>Training</strong></div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped mb-0">
                    <thead>
                        <tr>
                            <th>Course</th>
                            <th>Provider</th>
                            <th>Completion Date</th>
                            <th>Recertification Cycle</th>
                            <th>Status</th>
                            <th>Evidence Source</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var training in _record.TrainingRecords)
                        {
                            <tr>
                                <td>@training.CourseName</td>
                                <td>@training.Provider</td>
                                <td>@FormatDate(training.CompletionDate)</td>
                                <td>@GetRecertificationCycleText(training.RecertCycleMonths)</td>
                                <td>@training.Status</td>
                                <td>@training.EvidenceSource</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header"><strong>Skills</strong></div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped mb-0">
                    <thead>
                        <tr>
                            <th>Skill</th>
                            <th>Level</th>
                            <th>Required Level</th>
                            <th>Status</th>
                            <th>Evidence Source</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var skill in _record.Skills)
                        {
                            <tr>
                                <td>@skill.SkillName</td>
                                <td>@skill.WorkerLevel</td>
                                <td>@skill.RequiredLevel</td>
                                <td>@skill.Status</td>
                                <td>@skill.EvidenceSource</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header"><strong>Education</strong></div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped mb-0">
                    <thead>
                        <tr>
                            <th>Degree Type</th>
                            <th>Field</th>
                            <th>Verification Status</th>
                            <th>Evidence Source</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var edu in _record.Education)
                        {
                            <tr>
                                <td>@edu.Degree</td>
                                <td>@edu.Field</td>
                                <td>@edu.VerificationStatus</td>
                                <td>@edu.EvidenceSource</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public string workerId { get; set; } = string.Empty;

    private QualificationRecordModel? _record;
    private List<RoleRequirementTraceRecord> _mandatoryGaps = new();
    private List<RoleRequirementTraceRecord> _supportingGaps = new();

    protected override void OnParametersSet()
    {
        _record = QualificationRecordService.GetQualificationRecord(workerId);

        if (_record is null)
        {
            _mandatoryGaps = new List<RoleRequirementTraceRecord>();
            _supportingGaps = new List<RoleRequirementTraceRecord>();
            return;
        }

        _mandatoryGaps = _record.RoleRequirements
            .Where(requirement => requirement.RequirementType == RequirementAssessmentType.Mandatory && !requirement.IsMet)
            .ToList();

        _supportingGaps = _record.RoleRequirements
            .Where(requirement => requirement.RequirementType == RequirementAssessmentType.Supporting && !requirement.IsMet)
            .ToList();
    }

    private static string GetStatusBadgeClass(string status) => status switch
    {
        "Qualified" => "bg-success",
        "Not Qualified" => "bg-danger",
        _ => "bg-secondary"
    };

    private static string GetDecisionStatement(QualificationRecordModel record)
    {
        return record.QualificationStatus == "Not Qualified"
            ? $"This worker is NOT QUALIFIED due to {record.MandatoryGaps} unmet mandatory requirement(s)."
            : "This worker is QUALIFIED for this role.";
    }

    private static string GetRecertificationCycleText(int? recertCycleMonths)
    {
        return recertCycleMonths.HasValue
            ? $"{recertCycleMonths.Value} months"
            : "N/A";
    }

    private static string FormatDate(DateOnly date)
    {
        return date.ToString("yyyy-MM-dd");
    }

    private static string GetRequirementEvidenceDisplay(RoleRequirementTraceRecord requirement)
    {
        return requirement.IsMet
            ? requirement.MatchedEvidence
            : "-- (No evidence)";
    }
}
