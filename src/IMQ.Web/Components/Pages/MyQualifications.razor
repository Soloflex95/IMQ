    private string GetStatusBadgeClass(string status)
    {
        return status switch
        {
            "Qualified" => "bg-success",
            "NeedsReview" => "bg-warning text-dark",
            "NotQualified" => "bg-danger",
            "ManagerApproved" => "bg-info",
            "Draft" => "bg-secondary",
            _ => "bg-secondary"
        };
    }

    private string GetStatusText(string status)
    {
        return status switch
        {
            "Qualified" => "✓ Qualified",
            "NeedsReview" => "⚠ Needs Review",
            "NotQualified" => "✗ Not Qualified",
            "ManagerApproved" => "✓ Manager Approved",
            "Draft" => "Draft",
            _ => status
        };
    }

    private string GetExpiryClass(DateTime expiryDate)
    {
        var daysUntilExpiry = (expiryDate - DateTime.Now).Days;
        if (daysUntilExpiry < 0)
            return "text-danger fw-bold";
        if (daysUntilExpiry < 90)
            return "text-warning fw-bold";
        return "text-success";
    }

