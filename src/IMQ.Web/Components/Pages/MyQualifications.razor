@page "/qualifications"
@rendermode InteractiveServer

<PageTitle>My Qualifications - IMQ</PageTitle>

<h1>My Qualifications</h1>

<p class="lead">View and manage your professional qualifications and competencies.</p>

<div class="row mt-4">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">
                    <i class="bi bi-award"></i> Current Qualifications
                </h5>
            </div>
            <div class="card-body">
                @if (qualifications == null)
                {
                    <div class="text-center py-4">
                        <div class="spinner-border text-primary" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                        <p class="mt-2">Loading qualifications...</p>
                    </div>
                }
                else if (!qualifications.Any())
                {
                    <div class="alert alert-info">
                        <i class="bi bi-info-circle"></i>
                        <strong>No qualifications found.</strong> Click "Add Qualification" to get started.
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Skill</th>
                                    <th>Years Experience</th>
                                    <th>Proficiency</th>
                                    <th>Certification</th>
                                    <th>Status</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var qual in qualifications)
                                {
                                    <tr>
                                        <td>
                                            <strong>@qual.SkillName</strong>
                                        </td>
                                        <td>@qual.YearsExperience.ToString("F1")</td>
                                        <td>
                                            @if (qual.ProficiencyLevel.HasValue)
                                            {
                                                <span class="badge bg-secondary">Level @qual.ProficiencyLevel</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">N/A</span>
                                            }
                                        </td>
                                        <td>
                                            @if (!string.IsNullOrEmpty(qual.CertificationName))
                                            {
                                                <div>
                                                    <small class="text-muted">@qual.CertificationName</small>
                                                    @if (qual.CertificationExpiryDate.HasValue)
                                                    {
                                                        <br/>
                                                        <small class="@GetExpiryClass(qual.CertificationExpiryDate.Value)">
                                                            Expires: @qual.CertificationExpiryDate.Value.ToString("MMM dd, yyyy")
                                                        </small>
                                                    }
                                                </div>
                                            }
                                            else
                                            {
                                                <span class="text-muted">None</span>
                                            }
                                        </td>
                                        <td>
                                            <span class="badge @GetStatusBadgeClass(qual.Status)">
                                                @GetStatusText(qual.Status)
                                            </span>
                                        </td>
                                        <td>
                                            <button class="btn btn-sm btn-outline-primary" @onclick="() => EditQualification(qual.Id)">
                                                <i class="bi bi-pencil"></i> Edit
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
            <div class="card-footer">
                <button class="btn btn-success" @onclick="AddQualification">
                    <i class="bi bi-plus-circle"></i> Add Qualification
                </button>
                <button class="btn btn-outline-secondary ms-2" @onclick="UploadCV">
                    <i class="bi bi-file-earmark-arrow-up"></i> Upload CV
                </button>
            </div>
        </div>
    </div>
</div>

<div class="row mt-4">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header bg-info text-white">
                <h6 class="mb-0">
                    <i class="bi bi-briefcase"></i> Job Assignments
                </h6>
            </div>
            <div class="card-body">
                @if (jobAssignments == null || !jobAssignments.Any())
                {
                    <p class="text-muted">No current job assignments.</p>
                }
                else
                {
                    <ul class="list-group">
                        @foreach (var job in jobAssignments)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                <div>
                                    <strong>@job.JobTitle</strong>
                                    @if (job.IsPrimary)
                                    {
                                        <span class="badge bg-primary ms-2">Primary</span>
                                    }
                                    <br/>
                                    <small class="text-muted">Since @job.AssignedDate.ToString("MMM dd, yyyy")</small>
                                </div>
                                <button class="btn btn-sm btn-outline-info" @onclick="() => ViewJobDetails(job.JobId)">
                                    Details
                                </button>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>
    </div>
    
    <div class="col-md-6">
        <div class="card">
            <div class="card-header bg-warning text-dark">
                <h6 class="mb-0">
                    <i class="bi bi-exclamation-triangle"></i> Recent Assessments
                </h6>
            </div>
            <div class="card-body">
                @if (recentAssessments == null || !recentAssessments.Any())
                {
                    <p class="text-muted">No recent assessments.</p>
                }
                else
                {
                    <ul class="list-group">
                        @foreach (var assessment in recentAssessments)
                        {
                            <li class="list-group-item">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <strong>@assessment.JobTitle</strong>
                                        <br/>
                                        <small class="text-muted">@assessment.AssessedAt.ToString("MMM dd, yyyy")</small>
                                    </div>
                                    <div>
                                        <span class="badge @GetStatusBadgeClass(assessment.Status)">
                                            @GetStatusText(assessment.Status)
                                        </span>
                                        <div class="mt-1">
                                            <small class="text-muted">Match: @assessment.MatchScore.ToString("F0")%</small>
                                        </div>
                                    </div>
                                </div>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>
    </div>
</div>

