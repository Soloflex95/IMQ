@page "/workers"
@using Microsoft.AspNetCore.Components
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Team Management - IMQ</PageTitle>

<h1>
    <i class="bi bi-people"></i> Team Management
</h1>
<p class="lead">Manage your team's qualifications and assignments</p>
<p class="text-muted mb-3"><strong>Structured Qualification Records:</strong> IMQ organizes qualification evidence into a standardized record used for compliance evaluation.</p>

<div class="row mt-3">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <div class="d-flex gap-2 w-75">
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-search"></i></span>
                        <input type="text" class="form-control" placeholder="Search workers..." @bind="searchQuery" @bind:event="oninput" @onkeyup="FilterWorkers" />
                    </div>
                    <select class="form-select" style="max-width: 200px;" @bind="statusFilter" @bind:after="FilterWorkers">
                        <option value="">All Statuses</option>
                        <option value="Qualified">Qualified</option>
                        <option value="Needs Review">Needs Review</option>
                        <option value="Not Qualified">Not Qualified</option>
                    </select>
                </div>
                <button class="btn btn-success" @onclick="AddWorker">
                    <i class="bi bi-person-plus"></i> Add Worker
                </button>
            </div>
            <div class="card-body">
                @if (filteredWorkers == null)
                {
                    <div class="text-center py-4">
                        <div class="spinner-border text-primary" role="status"></div>
                        <p class="mt-2">Loading team...</p>
                    </div>
                }
                else if (!filteredWorkers.Any())
                {
                    <div class="alert alert-info">
                        <i class="bi bi-info-circle"></i> No workers found matching your search.
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th>Email</th>
                                    <th>Department</th>
                                    <th>Primary Job</th>
                                    <th>Qualifications</th>
                                    <th>Overall Status</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var worker in filteredWorkers)
                                {
                                    <tr>
                                        <td>
                                            <strong>@worker.FirstName @worker.LastName</strong>
                                            @if (worker.IsManager)
                                            {
                                                <span class="badge bg-primary ms-2">Manager</span>
                                            }
                                        </td>
                                        <td><small>@worker.Email</small></td>
                                        <td>@worker.Department</td>
                                        <td>@worker.PrimaryJob</td>
                                        <td>
                                            <div class="progress" style="height: 20px; width: 120px;">
                                                <div class="progress-bar bg-success" style="width: @worker.QualifiedCount%">
                                                    @worker.QualifiedCount
                                                </div>
                                                <div class="progress-bar bg-warning" style="width: @worker.ReviewCount%">
                                                    @worker.ReviewCount
                                                </div>
                                                <div class="progress-bar bg-danger" style="width: @worker.NotQualifiedCount%">
                                                    @worker.NotQualifiedCount
                                                </div>
                                            </div>
                                            <small class="text-muted">@worker.TotalQualifications total</small>
                                            <div><small class="text-muted">Mandatory: @worker.MandatoryMet/@worker.MandatoryTotal</small></div>
                                            <div><small class="text-muted">Supporting: @worker.SupportingMet/@worker.SupportingTotal</small></div>
                                        </td>
                                        <td>
                                            <span class="badge @GetOverallStatusBadgeClass(worker.OverallStatus)">
                                                @worker.OverallStatus
                                            </span>
                                        </td>
                                        <td>
                                            <div class="btn-group btn-group-sm" role="group">
                                                <button class="btn btn-outline-secondary text-secondary opacity-50" disabled title="Not available yet - planned feature" style="cursor: not-allowed;">
                                                    <i class="bi bi-eye"></i>
                                                </button>
                                                <button class="btn btn-outline-secondary text-secondary opacity-50" disabled title="Not available yet - planned feature" style="cursor: not-allowed;">
                                                    <i class="bi bi-clipboard-check"></i>
                                                </button>
                                                <button class="btn btn-outline-secondary text-secondary opacity-50" disabled title="Not available yet - planned feature" style="cursor: not-allowed;">
                                                    <i class="bi bi-pencil"></i>
                                                </button>
                                                @{
                                                    var workerId = GetWorkerId($"{worker.FirstName} {worker.LastName}");
                                                }
                                                @if (!string.IsNullOrWhiteSpace(workerId))
                                                {
                                                    <a class="btn btn-sm btn-outline-primary fw-semibold" href="/workers/@workerId/qualification-record" title="Structured Record">
                                                        <i class="bi bi-journal-check"></i> Structured Record
                                                    </a>
                                                    <a class="btn btn-sm btn-outline-dark fw-semibold" href="/workers/@workerId/qualification-decision" title="Qualification Decision">
                                                        <i class="bi bi-clipboard2-check"></i> Decision
                                                    </a>
                                                }
                                                else
                                                {
                                                    <button class="btn btn-sm btn-outline-secondary text-secondary opacity-50" disabled title="Not available for this worker in demo build" style="cursor: not-allowed;">
                                                        <i class="bi bi-journal-check"></i> Structured Record
                                                    </button>
                                                    <button class="btn btn-sm btn-outline-secondary text-secondary opacity-50" disabled title="Not available for this worker in demo build" style="cursor: not-allowed;">
                                                        <i class="bi bi-clipboard2-check"></i> Decision
                                                    </button>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<div class="row mt-4">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header bg-info text-white">
                <h5 class="mb-0">
                    <i class="bi bi-diagram-3"></i> Department Overview
                </h5>
            </div>
            <div class="card-body">
                @if (departmentStats != null)
                {
                    <canvas id="departmentChart" style="max-height: 300px;"></canvas>
                    <div class="mt-3">
                        @foreach (var dept in departmentStats)
                        {
                            <div class="d-flex justify-content-between mb-2">
                                <span>@dept.Name</span>
                                <span class="badge bg-secondary">@dept.WorkerCount workers</span>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
    
    <div class="col-md-6">
        <div class="card">
            <div class="card-header bg-warning text-dark">
                <h5 class="mb-0">
                    <i class="bi bi-exclamation-triangle"></i> Needs Attention
                </h5>
            </div>
            <div class="card-body">
                @if (attentionItems != null && attentionItems.Any())
                {
                    <div class="list-group">
                        @foreach (var item in attentionItems)
                        {
                            <div class="list-group-item">
                                <div class="d-flex w-100 justify-content-between">
                                    <h6 class="mb-1">@item.WorkerName</h6>
                                    <span class="badge @GetSeverityBadgeClass(item.Severity)">@item.Severity</span>
                                </div>
                                <p class="mb-1">@item.Issue</p>
                                <small class="text-muted">@item.JobTitle</small>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="alert alert-success mb-0">
                        <i class="bi bi-check-circle"></i> No items requiring attention.
                    </div>
                }
            </div>
        </div>
    </div>
</div>

