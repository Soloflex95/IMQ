@page "/compliance-alerts"
@using IMQ.Core.Entities
@using IMQ.Core.Enums
@using IMQ.Core.Interfaces
@inject IComplianceAlertService ComplianceAlertService
@rendermode InteractiveServer

<PageTitle>Compliance Alerts - IMQ</PageTitle>

<style>
    .review-disabled {
        color: var(--bs-secondary-color);
        cursor: not-allowed;
        text-decoration: underline;
    }
</style>

<h1><i class="bi bi-exclamation-triangle"></i> Compliance Alerts</h1>
<p class="lead text-muted">@alerts.Count unresolved compliance alerts</p>

<div class="card">
    <div class="card-header bg-warning-subtle">
        <strong>Unresolved Alerts</strong>
    </div>
    <div class="table-responsive">
        <table class="table table-striped mb-0">
            <thead>
                <tr>
                    <th scope="col">Alert ID</th>
                    <th scope="col">Worker</th>
                    <th scope="col">Issue</th>
                    <th scope="col">Severity</th>
                    <th scope="col">Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var alert in alerts)
                {
                    <tr>
                        <td>@alert.AlertId</td>
                        <td>@alert.WorkerName</td>
                        <td>
                            <div>@alert.Issue</div>
                            <small class="text-muted d-block">Impacts: @alert.RoleName</small>
                            @if (alert.DaysOverdue.HasValue)
                            {
                                <small class="text-muted d-block">@alert.DaysOverdue days overdue</small>
                            }
                        </td>
                        <td><span class="badge @GetSeverityBadgeClass(alert.Severity)">@alert.Severity</span></td>
                        <td>
                            <span class="review-disabled" role="button" title="Not available yet — requires electronic signature.">Review</span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<p class="text-muted fs-6 mt-2 mb-0">Note: Alert review workflows require electronic signature and are not enabled in this demo build.</p>

@code {
    private IReadOnlyList<ComplianceAlert> alerts = [];

    protected override void OnInitialized()
    {
        alerts = ComplianceAlertService.GetUnresolvedAlerts();
    }

    private static string GetSeverityBadgeClass(AlertSeverity severity)
    {
        return severity switch
        {
            AlertSeverity.High => "bg-danger",
            AlertSeverity.Medium => "bg-warning text-dark",
            _ => "bg-secondary"
        };
    }
}
